# Mizan root-level environment template.
#
# Worker-side env vars (LANGFUSE_HOST, DEFAULT_LLM_PROVIDER, DEFAULT_LLM_MODEL)
# live in apps/worker/wrangler.jsonc vars (committed defaults) and
# apps/worker/.dev.vars (local secrets — gitignored).
#
# Worker secrets in production (ANTHROPIC_API_KEY, OPENAI_API_KEY,
# OPENROUTER_API_KEY, BETTER_AUTH_SECRET) ship via `wrangler secret put`.
#
# No root-level env vars are required as of Phase 0. Later phases may add
# entries here for build-time tooling that runs outside the worker context.

# Cloudflare account ID. Wrangler reads it natively from this env var; export it
# before any `wrangler deploy` / `wrangler dev --remote` / `wrangler <resource>`
# command.
CLOUDFLARE_ACCOUNT_ID=
