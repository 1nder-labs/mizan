# Mizan environment variables (root .env template).
#
# Worker-side secrets live in apps/worker/.dev.vars (local) or are set via
# `wrangler secret put <KEY>` (production). Do NOT add API keys here.
#
# Phase 0 surfaces only the local Langfuse host so the worker can short-circuit
# observability when the stack is not running.

LANGFUSE_HOST=
