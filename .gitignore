# Agent context files (local only, never committed)
CLAUDE.md
AGENTS.md

# docs/ — only ship prd.md + solutions/ to the repo
/docs/*
!/docs/prd.md
!/docs/solutions/
!/docs/solutions/**

# Bun — bun.lock (text JSONC, Bun 1.2+ default) IS committed.
# bun.lockb (legacy binary lockfile) is defensively ignored.
bun.lockb
node_modules/
.bun/
bun-debug.log*

# Build / dist
dist/
build/
.wrangler/
.vite/
.turbo/
.dev.vars
.dev.vars.*
!.dev.vars.example
*.tsbuildinfo

# Env / secrets
.env
.env.*
!.env.example

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Claude Code local state (scheduled-task locks, agent worktrees)
.claude/

.agents/

# Test / coverage
coverage/
.nyc_output/
.vitest-cache/

# Local Langfuse data (Docker volumes)
docker/langfuse-db-data/

# Logs
*.log
logs/

# Playwright / agent-browser screenshot + dump scratch. `*.png` is global
# (pre-existing); the other formats are root-only, where ad-hoc screenshots land.
# Intentional source images live under apps/web/public, apps/web/src, packages,
# and synthetic-campaigns; force-add (git add -f) when committing one.
.playwright-mcp/
*.png
/*.jpg
/*.jpeg
/*.webp

# Playwright / agent-browser run artifacts — never committed (root + per-app)
test-results/
playwright-report/
.playwright/
apps/web/test-results/
apps/web/playwright-report/
apps/web/.playwright/

# Local dev upload fixtures (sample documents, generated)
/fixtures/

# Synthetic campaign packets — commit the usable data (campaign.json + the PDF
# evidence + README/INDEX), NOT the weasyprint HTML / generation scratch.
/synthetic-campaigns/**/*.html
/synthetic-campaigns/**/*.js
/synthetic-campaigns/**/*.mjs
/synthetic-campaigns/**/*.py
/synthetic-campaigns/**/*.sh
/synthetic-campaigns/**/*.jpg
/synthetic-campaigns/**/*.jpeg
/synthetic-campaigns/**/*.png
