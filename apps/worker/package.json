{
  "name": "@mizan/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "portless worker wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply DB --local",
    "db:migrate:prod": "wrangler d1 migrations apply DB --remote",
    "test": "NODE_OPTIONS='--max-old-space-size=8192' vitest run --project unit",
    "test:integration": "NODE_OPTIONS='--max-old-space-size=8192' vitest run --project integration",
    "test:all": "NODE_OPTIONS='--max-old-space-size=8192' vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tests/tsconfig.json"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "1.6.9",
    "@hono/zod-validator": "0.7.6",
    "@mastra/ai-sdk": "1.4.1",
    "@mizan/db": "workspace:*",
    "@mizan/mastra": "workspace:*",
    "ai": "6.0.175",
    "better-auth": "1.6.9",
    "better-auth-cloudflare": "0.3.0",
    "drizzle-orm": "0.45.2",
    "hono": "4.12.18",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "0.16.0",
    "@cloudflare/workers-types": "catalog:",
    "@mizan/shared": "workspace:*",
    "typescript": "6.0.3",
    "vitest": "4.1.5",
    "wrangler": "4.88.0"
  }
}
