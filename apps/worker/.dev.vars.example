ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=
BETTER_AUTH_SECRET=

# R2 API token — create at Cloudflare dashboard → R2 → Manage R2 API Tokens.
# Scope MUST be "Object Read Only" on the `mizan-uploads` bucket.
# Account ID + bucket name live in `wrangler.jsonc` `vars` (non-secret).
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Provider auto-resolves to the first key present (anthropic → openai → openrouter).
# Set only one key and the workflow routes to that provider automatically.
# Override with DEFAULT_LLM_PROVIDER=openai|anthropic|openrouter to force a specific one.
# DEFAULT_LLM_PROVIDER=

# Langfuse — local-only observability (Docker: localhost:3010).
# Values must match the LANGFUSE_INIT_* keys in docker-compose.langfuse.yml.
# Leave LANGFUSE_HOST="" (or unset) to disable — exporter returns null (fail-closed).
LANGFUSE_HOST=http://localhost:3010
LANGFUSE_PUBLIC_KEY=pk-lf-dev-mizan-local
LANGFUSE_SECRET_KEY=sk-lf-dev-mizan-local

# MOCK_LLM_RESPONSES={"extractCreatorIdDoc.extract":{}}
