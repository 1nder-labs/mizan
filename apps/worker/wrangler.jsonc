{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mizan",
  "main": "src/index.ts",
  "account_id": "558c97456d4a969cb82bee23d2054613",
  "compatibility_date": "2026-05-11",
  "compatibility_flags": ["nodejs_compat", "nodejs_compat_populate_process_env"],
  "observability": { "enabled": true },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mizan",
      "database_id": "86feeedb-734e-4d6c-8310-011dc58754ac",
      "migrations_dir": "../../packages/db/migrations",
    },
  ],
  "r2_buckets": [{ "binding": "R2_BUCKET", "bucket_name": "mizan-uploads" }],
  "vectorize": [{ "binding": "VECTORIZE", "index_name": "mizan-policy-corpus", "remote": true }],
  "kv_namespaces": [{ "binding": "KV", "id": "597f67d85db94ae4b4a90175fa465605" }],
  "queues": {
    "producers": [{ "binding": "BRIEF_QUEUE", "queue": "mizan-brief-jobs" }],
    "consumers": [
      {
        "queue": "mizan-brief-jobs",
        "max_batch_size": 1,
        "max_batch_timeout": 5,
        "max_concurrency": 3,
        "max_retries": 3,
        "dead_letter_queue": "mizan-brief-jobs-dlq",
        "retry_delay": 30,
      },
      {
        "queue": "mizan-brief-jobs-dlq",
        "max_batch_size": 1,
        "max_batch_timeout": 5,
        "max_concurrency": 1,
        "max_retries": 1,
      },
    ],
  },
  "assets": {
    "binding": "ASSETS",
    "directory": "../web/dist",
    "not_found_handling": "single-page-application",
    /**
     * Run the Worker ONLY for the API + health paths; every other path is
     * served by the assets system, which (via `not_found_handling:
     * single-page-application`) returns `index.html` for client-router routes
     * like `/login` or `/queue`. Without this scoping the Worker is invoked for
     * those non-asset paths and Hono 404s them, since the SPA fallback only
     * applies when the assets layer — not the Worker — answers. `!`-prefixed
     * exceptions could carve out asset-first subpaths under `/api` if needed.
     * Requires Wrangler >= 4.20 (we pin 4.88).
     */
    "run_worker_first": ["/api/*", "/health"],
  },
  "vars": {
    "DEFAULT_LLM_PROVIDER": "openai",
    "R2_ACCOUNT_ID": "558c97456d4a969cb82bee23d2054613",
    "R2_BUCKET_NAME": "mizan-uploads",
  },
}
