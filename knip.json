{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["portless"],
  "ignoreExportsUsedInFile": true,
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts", "scripts/lib/*.ts"],
      "ignoreDependencies": ["@socketsecurity/bun-security-scanner", "zod", "@mizan/mastra"]
    },
    "apps/worker": {
      "entry": ["tests/**/*.test.ts"],
      "ignore": ["src/auth/index.ts", "tests/setup/d1-types.d.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    "apps/web": {
      "entry": ["src/components/ui/*.tsx"]
    },
    "packages/db": {
      "ignoreDependencies": ["better-auth"]
    },
    "packages/mastra": {
      "ignoreDependencies": ["@mizan/worker"]
    },
    "packages/shared": {},
    "packages/eval": {
      "entry": ["src/**/*.eval.ts"]
    }
  }
}
