{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignoreBinaries": ["portless"],
  "workspaces": {
    ".": {
      "ignoreDependencies": ["@socketsecurity/bun-security-scanner"]
    },
    "apps/worker": {
      "entry": ["tests/**/*.test.ts"],
      "ignore": ["src/auth/index.ts", "tests/setup/d1-types.d.ts"],
      "ignoreDependencies": ["cloudflare"]
    },
    "apps/web": {
      "entry": ["src/components/ui/*.tsx"]
    },
    "packages/db": {
      "ignoreDependencies": ["better-auth"]
    },
    "packages/mastra": {},
    "packages/shared": {},
    "packages/eval": {}
  }
}
